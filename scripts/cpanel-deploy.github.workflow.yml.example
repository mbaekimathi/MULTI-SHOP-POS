# Copy to .github/workflows/cpanel-deploy.yml when your GitHub PAT has the "workflow" scope.
# See comments inside the file for secrets/variables.

name: cPanel deploy (pull + migrate DB)

on:
  workflow_dispatch:
  push:
    branches:
      - main

jobs:
  deploy:
    runs-on: ubuntu-latest
    if: github.event_name == 'workflow_dispatch' || vars.CPANEL_AUTO_DEPLOY == 'true'

    steps:
      - name: SSH — pull, migrate, restart Passenger
        uses: appleboy/ssh-action@v1.2.0
        env:
          CPANEL_APP_PATH: ${{ secrets.CPANEL_APP_PATH }}
          DEPLOY_BRANCH: ${{ github.ref_name }}
        with:
          host: ${{ secrets.CPANEL_SSH_HOST }}
          username: ${{ secrets.CPANEL_SSH_USER }}
          key: ${{ secrets.CPANEL_SSH_KEY }}
          script_stop: true
          envs: CPANEL_APP_PATH,DEPLOY_BRANCH
          script: |
            set -euo pipefail
            cd "$CPANEL_APP_PATH"
            git fetch origin
            git checkout "$DEPLOY_BRANCH"
            git pull origin "$DEPLOY_BRANCH"
            if command -v python3 >/dev/null 2>&1; then
              python3 migrate_db.py
            else
              python migrate_db.py
            fi
            mkdir -p tmp
            touch tmp/restart.txt
            echo "Deploy complete."
