# Secrets — never commit. Each machine (dev / cPanel) keeps its own .env; pushing would not
# "update" hosted credentials safely and could leak secrets. Use .env.example as the template only.
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
.venv/
venv/
*.egg-info/
.pytest_cache/

# Local scratch / agent extract dumps (not part of the app)
tmp_*/
.tmp/
.qodo/
**/.qodo/

# IDE / OS
.idea/
.vscode/
node_modules/
.DS_Store
Thumbs.db

# Backups / archives (do not push)
*.zip

# User uploads (keep folder placeholders only)
static/uploads/items/
static/uploads/profiles/*
!static/uploads/profiles/.gitkeep
