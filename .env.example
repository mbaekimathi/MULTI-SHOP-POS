# Copy to .env and fill in your values.
# Hosted extras (HTTPS cookies, proxy, PUBLIC_APP_URL) still auto-detect when omitted.

FLASK_SECRET_KEY=change-me-in-production

# --- Database ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=richcom

