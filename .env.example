# Loaded automatically; override secrets in .env (not committed).
#
# On cPanel / Passenger hosting the app auto-detects:
#   - RICHCOM_HOSTED
#   - MYSQL_HOST / MYSQL_PORT
#   - MYSQL_USER / MYSQL_DATABASE  (from cPanel user + folder name, e.g. kwetufar_karisma)
#   - SESSION_COOKIE_SECURE / TRUST_PROXY_HEADERS
#   - PUBLIC_APP_URL from the request Host / Website domain when not set
#
# Local Windows/macOS keeps root MySQL defaults unless you set MYSQL_* below.

FLASK_SECRET_KEY=change-me-in-production
SESSION_LIFETIME_DAYS=90

# Employee portal: auto sign-out after inactivity (minutes). Can also be changed in System settings.
EMPLOYEE_SESSION_IDLE_MINUTES=5
EMPLOYEE_SESSION_IDLE_WARN_SECONDS=60

# --- Hosted cPanel: usually only these are required ---
# MYSQL_PASSWORD=your_cpanel_db_password
# MYSQL_USER=kwetufar_karisma
# MYSQL_DATABASE=kwetufar_karisma
#
# Force hosted or local when auto-detect is wrong:
# RICHCOM_HOSTED=1
# RICHCOM_HOSTED=0

# --- Local MySQL (used when not hosted) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=multi_pos

# Optional: public HTTPS base (auto from request / Company / Website domain if omitted)
# PUBLIC_APP_URL=https://your-domain.com

# Optional STK callbacks (override Company settings)
# DARAJA_CALLBACK_URL=https://your-domain.com/api/daraja/mpesa-callback
# DARAJA_CALLBACK_URL_LOCAL=https://your-ngrok-url.ngrok-free.app/api/daraja/mpesa-callback

# Google Maps — company/shop location picker (Maps JavaScript API + Places API)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# SMTP — employee signup & approval emails (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=1
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your@gmail.com
