# Loaded automatically; override secrets in .env (not committed).

FLASK_SECRET_KEY=change-me-in-production
SESSION_LIFETIME_DAYS=90
SESSION_COOKIE_SECURE=0

# 0 = local MySQL (root), 1 = hosted/cPanel defaults
RICHCOM_HOSTED=0

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=richcom
