FLASK_SECRET_KEY=change-me-in-production
# Set to 1 on production hosting to use hosted MySQL defaults (twigabea_pos user/db; omit locally).
RICHCOM_HOSTED=0
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
# Local dev: copy this file to .env and set MYSQL_PASSWORD if MySQL rejects "root" with no password
# (error 1045 "using password: NO"). Use the same password you use in MySQL Workbench / phpMyAdmin.
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=richcom
