# =============================================================================
# Environment defaults (committed). The app loads this file automatically,
# then loads optional ".env" in the same folder — any key in ".env" wins.
# Use ".env" only for secrets or machine-specific overrides (do not commit ".env").
# =============================================================================

# --- Flask ---
# Required in production; optional locally (app falls back to a dev default).
FLASK_SECRET_KEY=change-me-in-production
# Optional: FLASK_ENV=development

# --- Session / "Remember this device" ---
# How long a remembered session lasts. Default 90 days.
SESSION_LIFETIME_DAYS=90
# Set to 1 in production (HTTPS) so the session cookie is marked Secure.
# Leave unset/0 for local http://127.0.0.1 development.
SESSION_COOKIE_SECURE=0

# --- MySQL connection (PyMySQL) ---
# Local: keep RICHCOM_HOSTED unset or 0 so the app uses root-style defaults below.
# Production server: set RICHCOM_HOSTED=1 for hosted defaults (see database.py _config).
RICHCOM_HOSTED=0

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# If MySQL returns error 1045 "using password: NO", set the same password you use in Workbench / phpMyAdmin.
MYSQL_PASSWORD=

# Schema name (must exist in MySQL). Hyphens are allowed in the name.
MYSQL_DATABASE=richcom
